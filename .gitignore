# ============================================
# 慧策 (HuìCè) - Git 忽略配置
# ============================================

# 依赖（前端 + 后端）
**/node_modules/

# 环境变量（含 API Key，绝不提交）
**/.env
!**/.env.example

# 日志
**/*.log
**/npm-debug.log*

# 上传的临时文件
**/uploads/

# 构建产物
**/dist/
**/build/
**/.vite/

# 编辑器与系统
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# TRAE / IDE 配置
.trae/

# 测试覆盖率
coverage/

# 本地缓存
**/.cache/
**/.parcel-cache/
